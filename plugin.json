{
  "spec": "soksak-spec-plugin@0.0.1",
  "id": "soksak-plugin-lgtv-remote",
  "name": {
    "ko": "LG TV 리모컨",
    "en": "LG TV Remote"
  },
  "version": "0.0.1",
  "repo": "https://github.com/soksak-ai/soksak-plugin-lgtv-remote.git",
  "description": {
    "en": "LG webOS TV remote — control power/volume/channel/d-pad/input/media/keyboard via modal overlay and CLI/MCP commands. Direct SSAP WebSocket connection + Wake-on-LAN (net.udp.send).",
    "ko": "LG webOS TV 리모컨 — 전원/볼륨/채널/방향키/입력/미디어/키보드를 모달 오버레이와 CLI/MCP 명령으로 조작한다. SSAP WebSocket 직결 + Wake-on-LAN(net.udp.send)."
  },
  "entry": "main.js",
  "permissions": [
    "ui",
    "ui:overlay:screen",
    "ui:titlebar",
    "commands",
    "commands:destructive",
    "commands:inject",
    "storage",
    "process",
    "network"
  ],
  "contributes": {
    "commands": [
      {
        "name": "connect",
        "title": {
          "en": "Connect TV",
          "ko": "TV 연결"
        }
      },
